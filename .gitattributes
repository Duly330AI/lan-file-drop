# Normalize line endings: auto-detect text, store as LF in the repo.
* text=auto eol=lf

# Explicit text files (LF in repo)
*.cs        text eol=lf
*.csproj    text eol=lf
*.sln       text eol=lf
*.axaml     text eol=lf
*.xaml      text eol=lf
*.json      text eol=lf
*.xml       text eol=lf
*.props     text eol=lf
*.targets   text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.editorconfig text eol=lf
*.gitattributes text eol=lf
*.gitignore text eol=lf

# Windows-specific scripts keep CRLF
*.cmd       text eol=crlf
*.bat       text eol=crlf
*.ps1       text eol=crlf

# Binary files: never normalize or diff as text
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.dll       binary
*.exe       binary
*.pdb       binary
*.snk       binary
*.ttf       binary
*.otf       binary
*.woff      binary
*.woff2     binary
