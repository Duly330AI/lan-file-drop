<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="820" d:DesignHeight="720"
        x:Class="LanFileDrop.App.MainWindow"
        Width="820" Height="720"
        MinWidth="640" MinHeight="520"
        Title="LAN File Drop">

    <Window.Styles>
        <!-- Card container -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource ThemeBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderMidBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style Selector="TextBlock.sectionTitle">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="Opacity" Value="0.7" />
        </Style>
        <Style Selector="Border.dropzone">
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderMidBrush}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="MinHeight" Value="96" />
        </Style>
    </Window.Styles>

    <DockPanel>

        <!-- Top: title + status banner -->
        <StackPanel DockPanel.Dock="Top" Margin="20,20,20,0" Spacing="8">
            <TextBlock Text="LAN File Drop" FontSize="24" FontWeight="Bold" />
            <Border Background="#33F2A900" BorderBrush="#F2A900" BorderThickness="1"
                    CornerRadius="6" Padding="12,10">
                <TextBlock TextWrapping="Wrap"
                           Text="Early MVP shell - manual transfer is explicit: select files, prepare manifest, start receiver, accept, then send." />
            </Border>
        </StackPanel>

        <ScrollViewer Padding="20,12,20,20">
            <StackPanel>

                <!-- Safety bullets -->
                <Border Classes="card">
                    <StackPanel Spacing="4">
                        <TextBlock Classes="sectionTitle" Text="Safety" />
                        <TextBlock Text="• No admin rights" />
                        <TextBlock Text="• No SMB" />
                        <TextBlock Text="• No credentials" />
                        <TextBlock Text="• No command execution" />
                        <TextBlock Text="• Receiver confirmation required" />
                        <TextBlock Text="• Local network only" />
                    </StackPanel>
                </Border>

                <!-- 1. Local device -->
                <Border Classes="card">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="sectionTitle" Text="Local device" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Display name:" Classes="muted" />
                            <TextBlock Text="this-device (placeholder)" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Status:" Classes="muted" />
                            <TextBlock Text="Not connected · UI shell only" FontWeight="SemiBold" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 2. Send files -->
                <Border Classes="card">
                    <StackPanel>
                        <TextBlock Classes="sectionTitle" Text="Send files" />
                        <Border Classes="dropzone">
                            <StackPanel VerticalAlignment="Center" Spacing="8">
                                <TextBlock x:Name="SelectedFilesSummaryText"
                                           HorizontalAlignment="Center"
                                           Text="No files selected"
                                           FontWeight="SemiBold" />
                                <TextBlock x:Name="SelectedFilesStatusText"
                                           HorizontalAlignment="Center"
                                           Classes="muted"
                                           TextWrapping="Wrap"
                                           Text="Select files to preview names and sizes. Nothing is sent yet." />
                                <ScrollViewer MaxHeight="160"
                                              HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="SelectedFilesPreviewPanel" Spacing="4" />
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                        <StackPanel Spacing="4" Margin="0,0,0,12">
                            <TextBlock Text="Send readiness" FontWeight="SemiBold" />
                            <TextBlock Text="Ready checks only - nothing sent until you click Send prepared transfer."
                                       Classes="muted"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="ReadinessPeerText"
                                       Classes="muted"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="ReadinessFilesText"
                                       Classes="muted"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="ReadinessTransferText"
                                       Classes="muted"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="SelectFilesButton"
                                    Content="Select files…"
                                    Click="OnSelectFilesClick" />
                            <Button x:Name="ClearSelectionButton"
                                    Content="Clear selection"
                                    IsEnabled="False"
                                    Click="OnClearSelectionClick" />
                            <Button x:Name="PrepareTransferDraftButton"
                                    Content="Prepare transfer draft"
                                    IsEnabled="False"
                                    Click="OnPrepareTransferDraftClick" />
                            <Button x:Name="PrepareManifestButton"
                                    Content="Prepare manifest"
                                    IsEnabled="False"
                                    Click="OnPrepareManifestClick" />
                            <Button x:Name="SendButton"
                                    Content="Send prepared transfer"
                                    IsEnabled="False"
                                    Click="OnSendPreparedTransferClick" />
                        </StackPanel>
                        <Border x:Name="OutgoingDraftPanel"
                                IsVisible="False"
                                BorderBrush="{DynamicResource ThemeBorderMidBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12"
                                Margin="0,12,0,0">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Outgoing transfer draft" FontWeight="SemiBold" />
                                <TextBlock x:Name="OutgoingDraftPeerText"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="OutgoingDraftFilesText"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="OutgoingDraftManifestText"
                                           Classes="muted"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="OutgoingDraftSafetyText"
                                           Classes="muted"
                                           TextWrapping="Wrap" />
                                <Button x:Name="ClearOutgoingDraftButton"
                                        Content="Clear draft"
                                        IsEnabled="False"
                                        HorizontalAlignment="Left"
                                        Click="OnClearOutgoingDraftClick" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- 3. Peers -->
                <Border Classes="card">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="sectionTitle" Text="Peers" />
                        <Border BorderBrush="{DynamicResource ThemeBorderMidBrush}" BorderThickness="1"
                                CornerRadius="6" Padding="16" MinHeight="64">
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="PeerPlaceholderText"
                                           Classes="muted"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Text="No peers — discovery is not implemented yet." />
                                <TextBlock x:Name="ValidatedManualPeerText"
                                           IsVisible="False"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBox x:Name="ManualPeerInput"
                                     PlaceholderText="[LAN-IP]:5000"
                                     Width="240"
                                     TextChanged="OnManualPeerInputTextChanged" />
                            <Button x:Name="ValidatePeerButton"
                                    Content="Validate peer"
                                    Click="OnValidatePeerClick" />
                            <Button x:Name="ProbeConnectionButton"
                                    Content="Probe connection"
                                    IsEnabled="False"
                                    Click="OnProbeConnectionClick" />
                        </StackPanel>
                        <TextBlock x:Name="ManualPeerStatusText"
                                   Classes="muted"
                                   Text="Manual peer validation and probe only — no files are sent and no transfer is started."
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- 4. Incoming transfer -->
                <Border Classes="card">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="sectionTitle" Text="Incoming transfer" />
                        <Border BorderBrush="{DynamicResource ThemeBorderMidBrush}" BorderThickness="1"
                                CornerRadius="6" Padding="16">
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button x:Name="SelectReceiveFolderButton"
                                            Content="Select receive folder"
                                            Click="OnSelectReceiveFolderClick" />
                                    <TextBlock x:Name="ReceiveFolderStatusText"
                                               Classes="muted"
                                               VerticalAlignment="Center"
                                               Text="No receive folder selected" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Port:"
                                               Classes="muted"
                                               VerticalAlignment="Center" />
                                    <TextBox x:Name="ReceivePortInput"
                                             Width="88"
                                             Text="5000" />
                                    <Button x:Name="StartReceiverButton"
                                            Content="Start receiver"
                                            IsEnabled="False"
                                            Click="OnStartReceiverClick" />
                                    <Button x:Name="StopReceiverButton"
                                            Content="Stop receiver"
                                            IsEnabled="False"
                                            Click="OnStopReceiverClick" />
                                </StackPanel>
                                <TextBlock x:Name="ReceiverStatusText"
                                           Classes="muted"
                                           TextWrapping="Wrap"
                                           Text="Receiver is stopped. It starts only from an explicit click and handles one transfer." />
                                <TextBlock x:Name="IncomingRequestSummaryText"
                                           TextWrapping="Wrap"
                                           Text="No incoming transfer is active." />
                                <TextBlock x:Name="IncomingRequestFilesText"
                                           Classes="muted"
                                           TextWrapping="Wrap"
                                           Text="No request metadata yet." />
                                <TextBlock x:Name="IncomingRequestIntegrityText"
                                           Classes="muted"
                                           TextWrapping="Wrap"
                                           Text="No files are written before Accept." />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button x:Name="AcceptIncomingButton"
                                            Content="Accept"
                                            IsEnabled="False"
                                            Click="OnAcceptIncomingClick" />
                                    <Button x:Name="RejectIncomingButton"
                                            Content="Reject"
                                            IsEnabled="False"
                                            Click="OnRejectIncomingClick" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- 5. Transfer log -->
                <Border Classes="card">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="sectionTitle" Text="Transfer log" />
                        <StackPanel Spacing="4">
                            <TextBlock Classes="muted" Text="[sample] UI shell started — no transfers performed." />
                            <TextBlock Classes="muted" Text="No transfer activity yet." />
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
